#!/bin/bash
# Pre-commit hook: gitleaks + lint-staged.

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

ERRORS=0

echo -n "  gitleaks (secrets scan)... "
if command -v gitleaks >/dev/null 2>&1; then
  if gitleaks protect --staged --redact --verbose=false --config=.gitleaks.toml >/dev/null 2>&1; then
    echo -e "${GREEN}PASS${NC}"
  else
    echo -e "${RED}FAIL${NC}"
    gitleaks protect --staged --redact --verbose=true --config=.gitleaks.toml
    ERRORS=$((ERRORS+1))
  fi
else
  echo -e "${YELLOW}SKIP${NC} (install with: brew install gitleaks)"
fi

echo -n "  lint-staged (eslint + design tokens)... "
if npx lint-staged >/dev/null 2>&1; then
  echo -e "${GREEN}PASS${NC}"
else
  echo -e "${RED}FAIL${NC}"
  npx lint-staged
  ERRORS=$((ERRORS+1))
fi

if [ $ERRORS -gt 0 ]; then
  echo -e "${RED}Commit blocked.${NC}"
  exit 1
fi

exit 0
