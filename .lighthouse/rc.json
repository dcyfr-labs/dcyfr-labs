{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "startServerCommand": "npm run start",
      "startServerReadyPattern": "Ready",
      "startServerReadyTimeout": 30000,
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/blog",
        "http://localhost:3000/work",
        "http://localhost:3000/about",
        "http://localhost:3000/contact",
        "http://localhost:3000/activity"
      ],
      "settings": {
        "chromeFlags": "--no-sandbox --headless --disable-gpu",
        "configPath": "./.lighthouse/config.json",
        "extraHeaders": "{\"x-vercel-protection-bypass\": \"${VERCEL_AUTOMATION_BYPASS_SECRET}\", \"x-vercel-set-bypass-cookie\": \"samesitenone\"}"
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./lighthouse"
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.7 }],
        "categories:accessibility": ["warn", { "minScore": 0.85 }],
        "categories:best-practices": ["warn", { "minScore": 0.85 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "valid-source-maps": ["warn", { "minScore": 0.5 }],
        "unused-javascript": ["warn", { "maxLength": 10 }],
        "legacy-javascript": ["warn", { "maxLength": 5 }],
        "mainthread-work-breakdown": ["warn", { "minScore": 0.5 }],
        "max-potential-fid": ["warn", { "minScore": 0.5 }],
        "render-blocking-resources": ["warn", { "maxLength": 5 }],
        "interactive": ["warn", { "minScore": 0.5 }],
        "largest-contentful-paint": ["warn", { "minScore": 0.5 }],
        "bootup-time": ["warn", { "minScore": 0.5 }]
      }
    }
  }
}
