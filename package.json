{
  "name": "dcyfr-labs",
  "version": "2026.5.11",
  "private": true,
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "scripts": {
    "dev": "op run --env-file=.env -- node scripts/dev-with-cache.mjs",
    "dev:fast": "op run --env-file=.env -- next dev --turbopack --port 3000",
    "dev:https": "op run --env-file=.env -- node server.mjs",
    "dev:fresh": "op run --env-file=.env -- node scripts/dev-with-cache.mjs --kill-port",
    "port:check": "node scripts/port-utils.mjs check",
    "port:kill": "node scripts/port-utils.mjs kill",
    "build": "npm run validate:content && npm run build:search && npm run build:populate-cache && npm run sync:metrics:quick && next build",
    "build:search": "tsx src/lib/search/build-index.ts",
    "build:populate-cache": "node scripts/populate-build-cache.mjs",
    "start": "next start",
    "setup": "npm install && cp .env.example .env.local 2>/dev/null || true && npm run build && npm run test:run",
    "prepare": "husky",
    "lint": "node scripts/run-eslint.mjs",
    "lint:fix": "node scripts/run-eslint.mjs --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test:run && npm run build",
    "doctor": "npm run check && npm run perf:check",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "PLAYWRIGHT_USE_PROD=1 playwright test",
    "test:e2e:dev": "PLAYWRIGHT_USE_PROD=0 playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test e2e/visual --reporter=html",
    "test:visual:update": "playwright test e2e/visual --update-snapshots",
    "test:red-team": "vitest run --config vitest.red-team.config.ts",
    "validate:content": "node scripts/validate.mjs content",
    "validate:design": "node scripts/validate.mjs design",
    "validate:frontmatter": "node scripts/validate.mjs frontmatter",
    "validate:tokens": "node scripts/validation/validate-design-tokens.mjs",
    "sync:metrics:quick": "tsx scripts/sync-production-metrics.mjs --quick",
    "release:bump": "node scripts/release/bump-version.mjs",
    "release:changelog": "node scripts/release/generate-changelog-entry.mjs",
    "release:notes": "node scripts/release/create-release-notes.mjs",
    "scan:gitleaks:local": "gitleaks protect --staged --redact --config=.gitleaks.toml",
    "scan:gitleaks:all": "gitleaks detect --source . --redact --config=.gitleaks.toml",
    "sbom:generate": "node scripts/security/generate-sbom.mjs",
    "lhci:autorun": "lhci autorun --config .lighthouse/rc.json",
    "lhci:analyze": "node scripts/analyze-core-web-vitals.mjs",
    "perf:check": "npm run build && node scripts/performance/check-bundle-size.mjs",
    "perf:analyze": "ANALYZE=true npm run build",
    "lint:ci": "node scripts/run-eslint.mjs",
    "lhci:assert": "lhci assert --config .lighthouse/rc.json",
    "validate:color-contrast": "node scripts/validate.mjs color-contrast",
    "update:baseline": "node scripts/ci/update-baseline-browser-mapping.mjs",
    "deploy:invalidate": "node scripts/invalidate-cache-on-deploy.mjs"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "node scripts/validation/validate-design-tokens.mjs --warn-only --files"
    ]
  },
  "dependencies": {
    "@axiomhq/js": "^1.6.0",
